-#include <pcre.h>
-}
+#define PCRE2_CODE_UNIT_WIDTH 8
+#include <pcre2.h>
 
 class CRegExp
 {
@@ -138,17 +130,17 @@ private:
   void Cleanup();
   inline bool IsValidSubNumber(int iSub) const;
 
