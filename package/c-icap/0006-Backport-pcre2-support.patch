+int pcre2_flag_parse(const char **f)
+{
+    const char *s = (*f);
+    if (*s != '<')
+        return 0;
+    s++;
+    const char *e = strchr(s, '>');
+    if (e)
+        *f = e;
+    else {
+        e = s + strlen(s);
+        *f = e - 1;
+    }
+    size_t len = e - s;
+    e--;
+    if (!len)
+        return 0;
+
+    int i;
+    for (i = 0; pcre2_flags[i].name != NULL; i++) {
+        if (strncmp(pcre2_flags[i].name, s, len) == 0)
+            return pcre2_flags[i].flag;
+    }
+    return 0;
