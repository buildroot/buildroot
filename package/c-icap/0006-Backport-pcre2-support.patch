        CFLAGS="$CFLAGS -I$pcrepath/include"
@@ -714,7 +755,7 @@ AC_CHECK_HEADERS(regex.h,
   )
 
 USE_REGEX=0
-if test "a$pcre" = "ayes" -o "a$posix_regex" = "ayes"; then
+if test "a$pcre2" = "ayes" -o "a$pcre" = "ayes" -o "a$posix_regex" = "ayes"; then
    USE_REGEX=1
 fi
 AC_SUBST(USE_REGEX)
